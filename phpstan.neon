includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/phpstan/phpstan/conf/bleedingEdge.neon

parameters:
    level: max

    paths:
        - app
        - config
        - bootstrap
        - database/factories
        - routes

    ignoreErrors:
        -
            message: '#Trait App\\Concerns\\BelongsToOrganization is used zero times#'
            path: app/Concerns/BelongsToOrganization.php
